    "solana",
    "token-2022",
    "confidential-transfer",
    "cli",
    "decrypt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@solana/zk-sdk": "0.4.2",
    "tsx": "^4.22.4",
    "vitest": "^2.1.9"
  }
}
