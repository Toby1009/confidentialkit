{
  "name": "@confidentialkit/sdk",
  "version": "0.1.0",
  "description": "Ergonomic TypeScript SDK for Solana Token-2022 Confidential Balances.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "solana",
    "token-2022",
    "confidential-transfer",
    "zk",
    "elgamal",
    "privacy"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@solana/zk-sdk": "0.4.2",
    "bs58": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Toby1009/confidentialkit.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Toby1009/confidentialkit/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/Toby1009/confidentialkit/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
